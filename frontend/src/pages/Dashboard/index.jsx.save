mport { useState, useEffect, useRef } from 'react';
import { useNavigate } from 'react-router-dom';
import axios from 'axios';
import DevPanel from './DevPanel';

const RARITY_COLORS = { Common:'#9ca3af', Uncommon:'#22c55e', Rare:'#3b9eff', Epic:'#a855f7', Legendary:'#f59e0b', Mythic:'#ef4444', Chroma:'#ec4899', Dev:'#282C34' };

function ChatPage({ user }) {
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState('');
  const [announce, setAnnounce] = useState('');
  const [connected, setConnected] = useState(false);
  const ws = useRef(null);
  const bottom = useRef(null);
  const ROLE_COLORS = {Player:'#9ca3af',VIP:'#f59e0b',Moderator:'#22c55e',Admin:'#3b82f6',Dev:'#ec4899'};
  const ROLE_ICONS = {VIP:'⭐',Moderator:'🛡️',Admin:'👑',Dev:'🛠️'};

  useEffect(() => {
    axios.get('/api/quests').then(res => setQuests(res.data.quests)).catch(() => {});
    axios.get('/api/quests/user', {headers:{authorization:token}}).then(res => setUserQuests(res.data.quests)).catch(() => {});
    const proto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const socket = new WebSocket(`${proto}//${window.location.host}/chat`);
    ws.current = socket;
    socket.onopen = () => setConnected(true);
    socket.onclose = () => setConnected(false);
    socket.onmessage = e => {
      const data = JSON.parse(e.data);
      if (data.type === 'history') setMessages(data.messages);
      else if (data.type === 'message' || data.type === 'announce')
        setMessages(prev => [...prev, {...data.message, isAnnounce: data.type === 'announce'}]);
    };
    return () => socket.close();
  }, []);

  useEffect(() => { bottom.current?.scrollIntoView({behavior:'smooth'}); }, [messages]);

  const send = () => {
    if (!input.trim() || !ws.current) return;
    ws.current.send(JSON.stringify({type:'send', token:localStorage.getItem('token'), content:input.trim()}));
    setInput('');
  };
  const sendAnnounce = () => {
    if (!announce.trim() || !ws.current) return;
    ws.current.send(JSON.stringify({type:'announce', token:localStorage.getItem('token'), content:announce.trim()}));
    setAnnounce('');
  };

  const iStyle = {flex:1,background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'12px',color:'#fff',fontFamily:'sans-serif',fontSize:'15px',padding:'12px 16px',outline:'none'};

  return (
    <div style={{display:'flex',flexDirection:'column',height:'calc(100vh - 64px)'}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'16px'}}>
        <div>
          <h1 style={{fontFamily:'Titan One,sans-serif',fontSize:'30px',margin:'0 0 4px',background:'linear-gradient(135deg,#e0e7ff,#a5b4fc)',WebkitBackgroundClip:'text',WebkitTextFillColor:'transparent'}}>Global Chat</h1>
          <p style={{margin:0,color:'rgba(255,255,255,0.35)',fontSize:'13px'}}>Talk with everyone on Lacket</p>
        </div>
        <div style={{display:'flex',alignItems:'center',gap:'6px',fontSize:'13px',color:connected?'#22c55e':'#ef4444'}}>
          <div style={{width:'8px',height:'8px',borderRadius:'50%',background:connected?'#22c55e':'#ef4444'}}/>
          {connected?'Connected':'Disconnected'}
        </div>
      </div>
      {['Dev','Admin'].includes(user?.role) && (
        <div style={{display:'flex',gap:'8px',marginBottom:'12px',background:'rgba(236,72,153,0.08)',border:'1px solid rgba(236,72,153,0.2)',borderRadius:'12px',padding:'10px 14px'}}>
          <input value={announce} onChange={e=>setAnnounce(e.target.value)} onKeyDown={e=>e.key==='Enter'&&sendAnnounce()} placeholder='📢 Send announcement...' style={{...iStyle,background:'transparent',border:'none',fontSize:'13px'}} />
          <button onClick={sendAnnounce} style={{background:'rgba(236,72,153,0.2)',border:'1px solid rgba(236,72,153,0.3)',borderRadius:'8px',color:'#f0abfc',fontSize:'13px',fontWeight:'700',padding:'6px 14px',cursor:'pointer'}}>Announce</button>
        </div>
      )}
      <div style={{flex:1,overflowY:'auto',display:'flex',flexDirection:'column',gap:'4px',marginBottom:'16px',paddingRight:'4px'}}>
        {messages.map((m,i) => m.isAnnounce ? (
          <div key={i} style={{background:'linear-gradient(135deg,rgba(236,72,153,0.1),rgba(168,85,247,0.08))',border:'1px solid rgba(236,72,153,0.3)',borderRadius:'12px',padding:'12px 16px',margin:'6px 0'}}>
<div style={{fontSize:'11px',color:'rgba(255,255,255,0.3)'}}>XP: {Math.floor((user.exp || 0) % 1000)} / 1000</div>
            <div style={{fontSize:'15px',color:'#e0e7ff'}}>{m.content}</div>
          </div>
        ) : (
          <div key={i} style={{display:'flex',gap:'10px',padding:'4px 8px',borderRadius:'8px',background:m.username===user?.username?'rgba(99,102,241,0.05)':'transparent'}}>
            <div style={{flexShrink:0,width:'32px',height:'32px',background:'rgba(99,102,241,0.15)',borderRadius:'8px',display:'flex',alignItems:'center',justifyContent:'center',fontSize:'14px'}}>{ROLE_ICONS[m.role]||'👤'}</div>
            <div style={{flex:1}}>
              <div style={{display:'flex',alignItems:'center',gap:'6px',marginBottom:'2px'}}>
                <span style={{fontSize:'14px',fontWeight:'800',color:ROLE_COLORS[m.role]||'#9ca3af'}}>{m.username}</span>
                {m.role && m.role!=='Player' && <span style={{fontSize:'10px',background:'rgba(99,102,241,0.1)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'4px',padding:'1px 6px',color:ROLE_COLORS[m.role],textTransform:'uppercase',letterSpacing:'0.5px'}}>{m.role}</span>}
                <span style={{fontSize:'11px',color:'rgba(255,255,255,0.2)'}}>{new Date(m.created_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span>
              </div>
              <div style={{fontSize:'15px',color:'#e0e7ff',lineHeight:'1.4'}}>{m.content}</div>
            </div>
          </div>
        ))}
        <div ref={bottom}/>
      </div>
      <div style={{display:'flex',gap:'10px'}}>
        <input value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==='Enter'&&send()} placeholder='Send a message...' maxLength={300} style={iStyle} />
        <button onClick={send} style={{background:'linear-gradient(135deg,#6366f1,#8b5cf6)',border:'none',borderRadius:'12px',color:'#fff',fontFamily:'sans-serif',fontSize:'15px',fontWeight:'700',padding:'12px 24px',cursor:'pointer'}}>Send</button>
      </div>
    </div>
  );
}

function ChangePasswordForm({ user }) {
  const [oldPw, setOldPw] = useState("");
  const [newPw, setNewPw] = useState("");
  const [msg, setMsg] = useState("");
  const [err, setErr] = useState("");
  const submit = async () => {
    setMsg(""); setErr("");
    try {
      const token = localStorage.getItem("token");
      await axios.post("/api/users/change-password", { oldPassword: oldPw, newPassword: newPw }, { headers: { authorization: token } });
      setMsg("Password changed!"); setOldPw(""); setNewPw("");
    } catch(e) { setErr(e.response?.data?.error || "Failed"); }
  };
  const iStyle = {width:"100%",padding:"9px",background:"rgba(99,102,241,0.08)",border:"1px solid rgba(99,102,241,0.2)",borderRadius:"8px",color:"white",fontSize:"13px",marginBottom:"8px",boxSizing:"border-box"};
  return (
    <div>
      <input type="password" value={oldPw} onChange={e=>setOldPw(e.target.value)} placeholder="Current password" style={iStyle} />
      <input type="password" value={newPw} onChange={e=>setNewPw(e.target.value)} placeholder="New password" style={iStyle} />
      <button onClick={submit} style={{background:"linear-gradient(135deg,#6366f1,#3b9eff)",border:"none",borderRadius:"8px",color:"white",fontSize:"13px",fontWeight:"600",padding:"9px 20px",cursor:"pointer"}}>Change Password</button>
      {msg && <div style={{color:"#22c55e",fontSize:"12px",marginTop:"8px"}}>{msg}</div>}
      {err && <div style={{color:"#f87171",fontSize:"12px",marginTop:"8px"}}>{err}</div>}
    </div>
  );
}

export default function Dashboard() {
  const navigate = useNavigate();
  const [user, setUser] = useState(null);
  const [leaderboard, setLeaderboard] = useState([]);
    const [ownedBlooks, setOwnedBlooks] = useState([]);
  const [packs, setPacks] = useState({});
  const [page, setPage] = useState('profile');
  const [opening, setOpening] = useState(null);
  const [reward, setReward] = useState(null);
  const [rewardRarity, setRewardRarity] = useState(null);

  // Multiplayer state
  const [mpMode, setMpMode] = useState('menu'); // menu, hosting, joining, lobby, playing, answered, gameover
  const [mpCode, setMpCode] = useState('');
  const [mpJoinCode, setMpJoinCode] = useState('');
  const [mpPlayers, setMpPlayers] = useState([]);
  const [mpQuestion, setMpQuestion] = useState(null);
  const [mpAnswered, setMpAnswered] = useState(null); // {correct, points}
  const [mpScores, setMpScores] = useState([]);
  const [mpFinalScores, setMpFinalScores] = useState([]);
  const [mpIsHost, setMpIsHost] = useState(false);
  const [mpUsername, setMpUsername] = useState('');
  const [mpError, setMpError] = useState('');
  const [mpQuestionNum, setMpQuestionNum] = useState(0);
  const [mpTotal, setMpTotal] = useState(0);
  const [mpTimeLeft, setMpTimeLeft] = useState(15);
  const [sets, setSets] = useState([]);
  const [friends, setFriends] = useState([]);
  const [trades, setTrades] = useState([]);
  const [tradeStep, setTradeStep] = useState('main'); // main, selectMyBlook, selectTheirBlook
  const [tradeTarget, setTradeTarget] = useState('');
  const [tradeMyBlook, setTradeMyBlook] = useState(null);
  const [tradeTheirBlook, setTradeTheirBlook] = useState(null);
  const [tradeTargetBlooks, setTradeTargetBlooks] = useState([]);
  const [tradeMyBlooks, setTradeMyBlooks] = useState([]);
  const [tradeMsg, setTradeMsg] = useState('');
  const [tradeErr, setTradeErr] = useState('');
  const [friendInput, setFriendInput] = useState('');
  const [friendMsg, setFriendMsg] = useState('');
  const [friendErr, setFriendErr] = useState('');
  const [selectedSet, setSelectedSet] = useState(null);
  const [quests, setQuests] = useState([]);
  const [userQuests, setUserQuests] = useState([]);  
  const [creatingSet, setCreatingSet] = useState(false);
  const [setTitle, setSetTitle] = useState('');
  const [setDesc, setSetDesc] = useState('');
  const [setQuestions, setSetQuestions] = useState([{question:'',answers:['','','',''],correct:0}]);
  const wsRef = useRef(null);
  const timerRef = useRef(null);

  useEffect(() => {
    const token = localStorage.getItem('token');
    if (!token) { navigate('/login'); return; }
    axios.get('/api/users/me', { headers: { authorization: token } })
      .then(res => setUser(res.data))
      .catch(() => { localStorage.removeItem('token'); navigate('/login'); });
    axios.get('/api/leaderboard').then(res => setLeaderboard(res.data)).catch(() => {});
        axios.get('/api/users/blooks', { headers: { authorization: token } }).then(res => setOwnedBlooks(res.data)).catch(err => console.error('blooks err', err));
    axios.get('/api/packs').then(res => setPacks(res.data)).catch(() => {});
    axios.get('/api/sets').then(res => setSets(res.data)).catch(() => {});
    axios.get('/api/friends', {headers:{authorization:token}}).then(res => setFriends(res.data)).catch(() => {});
    axios.get('/api/trades', {headers:{authorization:token}}).then(res => setTrades(res.data)).catch(() => {});

  }, []);

  useEffect(() => {
    return () => { if (wsRef.current) wsRef.current.close(); clearInterval(timerRef.current); };
  }, []);

  const connectWS = () => {
    const proto = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const ws = new WebSocket(`${proto}://${window.location.host}`);
    wsRef.current = ws;
    ws.onmessage = (e) => {
      const msg = JSON.parse(e.data);
      if (msg.type === 'hosted') {
        setMpCode(msg.code); setMpIsHost(true); setMpUsername(msg.username);
        setMpPlayers([{ username: msg.username, score: 0 }]); setMpMode('lobby');
      } else if (msg.type === 'joined') {
        setMpCode(msg.code); setMpIsHost(false); setMpUsername(msg.username); setMpMode('lobby');
      } else if (msg.type === 'playerjoined') {
        setMpPlayers(msg.players);
      } else if (msg.type === 'playerleft') {
        setMpPlayers(msg.players);
      } else if (msg.type === 'starting') {
        setMpMode('starting');
      } else if (msg.type === 'question') {
        setMpQuestion(msg); setMpQuestionNum(msg.index + 1); setMpTotal(msg.total);
        setMpAnswered(null); setMpMode('playing'); setMpTimeLeft(15);
        clearInterval(timerRef.current);
        timerRef.current = setInterval(() => setMpTimeLeft(t => { if (t <= 1) { clearInterval(timerRef.current); return 0; } return t - 1; }), 1000);
      } else if (msg.type === 'answered') {
        setMpAnswered({ correct: msg.correct, points: msg.points }); setMpMode('answered');
        clearInterval(timerRef.current);
      } else if (msg.type === 'timeout') {
        setMpScores(msg.scores || []); setMpMode('scores');
        clearInterval(timerRef.current);
      } else if (msg.type === 'gameover') {
        setMpFinalScores(msg.scores); setMpMode('gameover');
        clearInterval(timerRef.current);
        axios.get('/api/users/me', { headers: { authorization: localStorage.getItem('token') } }).then(r => setUser(r.data)).catch(() => {});
      } else if (msg.type === 'error') {
        setMpError(msg.message);
      }
    };
    ws.onclose = () => { if (mpMode !== 'gameover') setMpMode('menu'); };
    return ws;
  };

  const hostGame = () => {
    setMpError('');
    const ws = connectWS();
    ws.onopen = () => ws.send(JSON.stringify({ type: 'host', token: localStorage.getItem('token'), setId: selectedSet?.id || null }));
  };

  const joinGame = () => {
    if (!mpJoinCode.trim()) return;
    setMpError('');
    const ws = connectWS();
    ws.onopen = () => ws.send(JSON.stringify({ type: 'join', code: mpJoinCode.trim(), token: localStorage.getItem('token') }));
  };

  const startGame = () => wsRef.current?.send(JSON.stringify({ type: 'start' }));
  const sendAnswer = (idx) => { if (mpMode === 'playing') wsRef.current?.send(JSON.stringify({ type: 'answer', answer: idx })); };

  const leaveGame = () => {
    if (wsRef.current) wsRef.current.close();
    setMpMode('menu'); setMpCode(''); setMpJoinCode(''); setMpPlayers([]);
    setMpQuestion(null); setMpAnswered(null); setMpError(''); setMpIsHost(false);
    clearInterval(timerRef.current);
  };

  const sendFriendRequest = async () => {
    setFriendMsg(''); setFriendErr('');
    try {
      const token = localStorage.getItem('token');
      await axios.post('/api/friends-request', {username: friendInput}, {headers:{authorization:token}});
      setFriendMsg('Friend request sent!');
      setFriendInput('');
      axios.get('/api/friends', {headers:{authorization:token}}).then(res => setFriends(res.data));
    } catch(e) { setFriendErr(e.response?.data?.error || 'Failed'); }
  };
  const friendAction = async (friendId, action) => {
    try {
      const token = localStorage.getItem('token');
      await axios.post('/api/friends-action', {friendId, action}, {headers:{authorization:token}});
      axios.get('/api/friends', {headers:{authorization:token}}).then(res => setFriends(res.data));
    } catch(e) { console.error(e); }
  };
  const logout = () => { localStorage.removeItem('token'); navigate('/'); };
  const buyPack = async (packName) => {
    if (opening) return;
    setOpening(packName); setReward(null);
    try {
      const token = localStorage.getItem('token');
      const res = await axios.post('/api/buy-pack', { pack: packName }, { headers: { authorization: token } });
      setTimeout(() => { setReward(res.data.blook); setRewardRarity(res.data.rarity); setUser({...res.data.user, blooks: [...(user.blooks||[]), {blook_name: res.data.blook, rarity: res.data.rarity, count: 1}]}); setOpening(null); }, 1000);
    } catch (err) { alert(err.response?.data?.error || 'Failed'); setOpening(null); }
  };

  if (!user) return <div style={{minHeight:'100vh',background:'#05071a',display:'flex',alignItems:'center',justifyContent:'center',color:'#fff',fontSize:'20px'}}>Loading...</div>;

  const S = {
    page: {flex:1,padding:'32px 36px',overflowY:'auto'},
    h1: {fontFamily:'Titan One,sans-serif',fontSize:'30px',margin:'0 0 4px',background:'linear-gradient(135deg,#e0e7ff,#a5b4fc)',WebkitBackgroundClip:'text',WebkitTextFillColor:'transparent'},
    sub: {margin:'0 0 24px',color:'rgba(255,255,255,0.35)',fontSize:'13px'},
    card: {background:'linear-gradient(135deg,#0d1240,#0a0f2e)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'16px',padding:'24px'},
    btn: (c='#6366f1') => ({background:`linear-gradient(135deg,${c},${c}cc)`,border:'none',borderRadius:'12px',color:'white',fontWeight:'700',fontSize:'15px',padding:'12px 28px',cursor:'pointer'}),
    ghostBtn: {background:'rgba(99,102,241,0.1)',border:'1px solid rgba(99,102,241,0.3)',borderRadius:'12px',color:'#a5b4fc',fontWeight:'600',fontSize:'14px',padding:'11px 24px',cursor:'pointer'},
  };

  return (
    <div style={{display:'flex',height:'100vh',background:'#05071a',color:'#fff',fontFamily:'sans-serif',overflow:'hidden'}}>
      {/* SIDEBAR */}
      <div style={{width:'220px',height:'100vh',background:'linear-gradient(180deg,#0a0f2e,#060918)',borderRight:'1px solid rgba(99,102,241,0.15)',display:'flex',flexDirection:'column',flexShrink:0}}>
        <div style={{padding:'22px 20px 16px',borderBottom:'1px solid rgba(99,102,241,0.1)'}}>
          <div style={{display:'flex',alignItems:'center',gap:'10px'}}>
            <div style={{width:'32px',height:'32px',background:'linear-gradient(135deg,#3b9eff,#6366f1)',borderRadius:'8px',display:'flex',alignItems:'center',justifyContent:'center',fontSize:'15px',fontWeight:'900',color:'white',flexShrink:0}}>L</div>
            <div style={{fontFamily:'Titan One,sans-serif',fontSize:'22px',background:'linear-gradient(135deg,#818cf8,#c7d2fe)',WebkitBackgroundClip:'text',WebkitTextFillColor:'transparent'}}>Lacket</div>
          </div>
        </div>
        <div style={{padding:'10px',margin:'10px',background:'rgba(99,102,241,0.08)',borderRadius:'10px',display:'flex',alignItems:'center',gap:'8px'}}>
          <img src={`/content/blooks/${user.equipped_blook}`} style={{width:'34px',height:'34px',borderRadius:'7px'}} />
          <div>
            <div style={{fontSize:'13px',fontWeight:'700',color:'#e0e7ff'}}>{user.username}</div>
            <div style={{fontSize:'11px',color:'#f59e0b'}}>🪙 {user.tokens?.toLocaleString()}</div>
          </div>
        </div>
        <nav style={{flex:1,padding:'6px 10px'}}>
          {[['profile','👤','Profile'],['blooks','🃏','Blooks'],['market','🛒','Market'],['play','🎮','Play'],['sets','📝','My Sets'],['discover','🔍','Discover'],['chat','💬','Chat'],['friends','👥','Friends'],['trade','🎨','Trade'],['leaderboard','🏆','Leaderboard'],['settings','⚙️','Settings'],...(user?.role==='Dev'?[['dev','🛠️','Dev Panel']]:[])].map(([id,icon,label]) => (
            <button key={id} onClick={() => setPage(id)} style={{display:'flex',alignItems:'center',gap:'10px',width:'100%',padding:'10px 12px',marginBottom:'2px',border:'none',borderRadius:'9px',background:page===id?'rgba(99,102,241,0.2)':'transparent',color:page===id?'#a5b4fc':'rgba(255,255,255,0.45)',fontFamily:'sans-serif',fontSize:'13px',fontWeight:page===id?'700':'500',cursor:'pointer',textAlign:'left'}}>
              <span style={{fontSize:'16px'}}>{icon}</span>{label}
            </button>
          ))}
        </nav>
        <div style={{padding:'12px'}}>
          <button onClick={logout} style={{width:'100%',padding:'10px',background:'rgba(239,68,68,0.1)',border:'1px solid rgba(239,68,68,0.2)',borderRadius:'9px',color:'#f87171',fontFamily:'sans-serif',fontSize:'13px',fontWeight:'600',cursor:'pointer'}}>Logout</button>
        </div>
      </div>

      {/* MAIN */}
      <div style={S.page}>

        {/* PROFILE */}
        {page==='profile' && <>
          <h1 style={S.h1}>Profile</h1>
          <p style={S.sub}>Your account overview</p>
          <div style={{display:'grid',gridTemplateColumns:'280px 1fr',gap:'18px'}}>
            <div style={{...S.card,display:'flex',flexDirection:'column',alignItems:'center',textAlign:'center'}}>
              <img src={`/content/blooks/${user.equipped_blook}`} style={{width:'88px',height:'88px',borderRadius:'16px',border:'2px solid rgba(99,102,241,0.3)',marginBottom:'14px'}} />
              <div style={{fontSize:'22px',fontWeight:'800',color:'#e0e7ff'}}>{user.username}</div>
              <div style={{fontSize:'12px',color:'rgba(255,255,255,0.3)',marginTop:'3px',marginBottom:'16px'}}>Joined {new Date(user.created_at).toLocaleDateString()}</div>
              <div style={{background:'rgba(245,158,11,0.1)',border:'1px solid rgba(245,158,11,0.3)',borderRadius:'12px',padding:'14px 20px',width:'100%',marginBottom:'14px'}}>
                <div style={{fontSize:'28px',fontWeight:'800',color:'#f59e0b'}}>{user.tokens?.toLocaleString()}</div>
               {/* XP BAR */}
<div style={{background:'rgba(102,102,255,0.1)',border:'1px solid rgba(99,102,241,0.3)',borderRadius:'12px',padding:'14px 20px',width:'100%',marginTop:'10px'}}>
  <div style={{display:'flex',justifyContent:'space-between',marginBottom:'6px'}}>
    <div style={{fontSize:'12px',fontWeight:'700',color:'#a5b4fc'}}>Level {user.level || 1}</div>
    <div style={{fontSize:'11px',color:'rgba(255,255,255,0.3)}}>{(user.exp || 0) % 1000} / 1000 XP</div>
  </div>
  <div style={{background:'rgba(0,0,0,0.3)',borderRadius:'8px',height:'8px',overflow:'hidden'}}>
    <div style={{background:'linear-gradient(90deg,#3b9eff,#6366f1)',height:'100%',width:`${((user.exp || 0) % 1000) / 10}%`,transition:'width 0.3s'}}></div>
  </div>
</div> 
               <div style={{fontSize:'11px',color:'rgba(245,158,11,0.5)',textTransform:'uppercase'}}>Tokens</div>
              </div>
              <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'10px',width:'100%'}}>
                <div style={{background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.15)',borderRadius:'10px',padding:'12px'}}>
                  <div style={{fontSize:'20px',fontWeight:'800',color:'#a5b4fc'}}>#{leaderboard.findIndex(u=>u.username===user.username)+1||'—'}</div>
                  <div style={{fontSize:'10px',color:'rgba(255,255,255,0.3)',textTransform:'uppercase'}}>Rank</div>
                </div>
                <div style={{background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.15)',borderRadius:'10px',padding:'12px'}}>
                  <div style={{fontSize:'20px',fontWeight:'800',color:'#a5b4fc'}}>{(user.blooks||[]).length}</div>
                  <div style={{fontSize:'10px',color:'rgba(255,255,255,0.3)',textTransform:'uppercase'}}>Blooks</div>
                </div>
              </div>
            </div>
            <div style={{display:'flex',flexDirection:'column',gap:'16px'}}>
              <div style={{...S.card,flex:1}}>
              {/* QUESTS SECTION */}
<div style={{...S.card}}>
  <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'14px'}}>Active Quests</div>
  <div style={{display:'flex',flexDirection:'column',gap:'10px'}}>
    {userQuests.filter(q=>!q.completed).slice(0,3).map(q => (
      <div key={q.id} style={{background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.15)',borderRadius:'10px',padding:'12px'}}>
        <div style={{fontSize:'13px',fontWeight:'700',color:'#e0e7ff',marginBottom:'4px'}}>{q.title}</div>
        <div style={{fontSize:'11px',color:'rgba(255,255,255,0.4)',marginBottom:'8px'}}>{q.description}</div>
        <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
          <div style={{fontSize:'11px',color:'#f59e0b'}}>+{q.xp_reward} XP</div>
          <button onClick={() => axios.post('/api/quests/complete', {questId:q.id}, {headers:{authorization:localStorage.getItem('token')}}).then(r => {setUser(r.data.user); setUserQuests(userQuests.map(quest=>quest.id===q.id?{...quest,completed:1}:quest));}).catch(err=>alert(err.response?.data?.error))} style={{background:'rgba(99,102,241,0.15)',border:'1px solid rgba(99,102,241,0.3)',borderRadius:'6px',color:'#a5b4fc',fontSize:'11px',fontWeight:'600',padding:'5px 12px',cursor:'pointer',border:'none'}}>Complete</button>
        </div>
      </div>
    ))}
  </div>
</div>
              <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'14px'}}>Blook Showcase</div>
                <div style={{display:'grid',gridTemplateColumns:'repeat(5,1fr)',gap:'10px'}}>
                  {(user.blooks||[]).slice(0,5).map((b,i) => (
                    <div key={i} style={{background:'rgba(99,102,241,0.08)',border:`1px solid ${RARITY_COLORS[b.rarity]||'rgba(99,102,241,0.15)'}44`,borderRadius:'12px',padding:'14px',textAlign:'center'}}>
                      <img src={'/content/blooks/'+b.blook_name} onError={e=>{e.target.src='/content/blooks/Default.png'}} style={{width:'100%',maxWidth:'60px',height:'60px',objectFit:'contain'}} />
                      <div style={{fontSize:'11px',color:RARITY_COLORS[b.rarity]||'rgba(255,255,255,0.5)',marginTop:'8px',fontWeight:'600'}}>{b.blook_name.replace(/\.(png|gif)/,'')}</div>
                    </div>
                  ))}
                  {(!user.blooks||user.blooks.length===0) && <div style={{color:'rgba(255,255,255,0.2)',fontSize:'12px',gridColumn:'span 5',padding:'20px'}}>No blooks yet — buy packs!</div>}
                </div>
              </div>
            </div>
          </div>
        </>}

        {/* BLOOKS */}
        {page==='blooks' && <>
          <h1 style={S.h1}>Blooks</h1>
          <p style={S.sub}>Your collection</p>
          {(!user.blooks || user.blooks.length === 0) && <div style={{color:'rgba(255,255,255,0.3)',fontSize:'14px'}}>No blooks yet! Buy packs in the Market.</div>}
          <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(150px,1fr))',gap:'14px'}}>
            {(user.blooks||[]).map((b,i) => (
              <div key={i} style={{background:'linear-gradient(135deg,#0d1240,#0a0f2e)',border:`2px solid ${user.equipped_blook===b.blook_name?(RARITY_COLORS[b.rarity]||'#6366f1'):'rgba(99,102,241,0.2)'}`,borderRadius:'14px',padding:'16px',textAlign:'center'}}>
                <img src={'/content/blooks/'+b.blook_name} onError={e=>{e.target.src='/content/blooks/Default.png'}} style={{width:'80px',height:'80px',marginBottom:'8px',objectFit:'contain'}} />
                <div style={{fontSize:'13px',fontWeight:'700',color:'#e0e7ff',marginBottom:'2px'}}>{b.blook_name.replace(/\.(png|gif)/,'')}</div>
                <div style={{fontSize:'11px',fontWeight:'700',color:RARITY_COLORS[b.rarity]||RARITY_COLORS[b.rarity?.charAt(0).toUpperCase()+b.rarity?.slice(1)]||'#9ca3af',marginBottom:'2px'}}>{b.rarity?.charAt(0).toUpperCase()+b.rarity?.slice(1)}</div>
                {b.count > 1 && <div style={{fontSize:'11px',color:'rgba(255,255,255,0.3)',marginBottom:'8px'}}>x{b.count}</div>}
                {b.count <= 1 && <div style={{marginBottom:'8px'}}/>}
                {user.equipped_blook===b.blook_name
                  ? <div style={{fontSize:'12px',color:'#22c55e',fontWeight:'700'}}>✓ Equipped</div>
                  : <button onClick={()=>axios.post('/api/users/equip-blook',{blook:b.blook_name},{headers:{authorization:localStorage.getItem('token')}}).then(r=>setUser(prev=>({...r.data.user,blooks:prev.blooks})))} style={{background:'rgba(99,102,241,0.15)',border:'1px solid rgba(99,102,241,0.3)',borderRadius:'8px',color:'#a5b4fc',fontSize:'12px',fontWeight:'600',padding:'6px 12px',cursor:'pointer',width:'100%'}}>Equip</button>
                }
              </div>
            ))}
          </div>
        </>}

        {/* MARKET */}
        {page==='market' && <>
          <h1 style={S.h1}>Market</h1>
          <p style={S.sub}>Open packs to get blooks</p>
          {reward && (
            <div style={{...S.card,marginBottom:'24px',textAlign:'center',border:'1px solid rgba(99,102,241,0.4)'}}>
              <div style={{fontSize:'14px',color:'rgba(255,255,255,0.5)',marginBottom:'8px'}}>You got...</div>
              <img src={`/content/blooks/${reward}`} style={{width:'100px',height:'100px',marginBottom:'10px'}} />
              <div style={{fontSize:'22px',fontWeight:'800',color:'#a5b4fc',marginBottom:'4px'}}>{reward.replace(/\.(png|gif)/,'')}</div>
              {rewardRarity && <div style={{fontSize:'13px',fontWeight:'700',marginBottom:'14px',color:RARITY_COLORS[rewardRarity]||'#fff'}}>{rewardRarity}</div>}
              <button onClick={()=>setReward(null)} style={S.ghostBtn}>Nice!</button>
            </div>
          )}
          <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(200px,1fr))',gap:'16px'}}>
            {Object.entries(packs).map(([name, pack]) => (
              <div key={name} style={{background:`linear-gradient(135deg,${pack.color1}22,${pack.color2}22)`,border:`1px solid ${pack.color1}44`,borderRadius:'16px',padding:'24px',textAlign:'center'}}>
                <div style={{width:'80px',height:'80px',background:`linear-gradient(135deg,${pack.color1},${pack.color2})`,borderRadius:'16px',margin:'0 auto 16px',display:'flex',alignItems:'center',justifyContent:'center',fontSize:'32px',boxShadow:`0 8px 24px ${pack.color1}44`}}>📦</div>
                <div style={{fontSize:'16px',fontWeight:'800',color:'#e0e7ff',marginBottom:'6px'}}>{name}</div>
                <div style={{fontSize:'12px',color:'rgba(255,255,255,0.3)',marginBottom:'16px'}}>{Object.keys(pack.blooks).length} possible blooks</div>
                <button onClick={()=>buyPack(name)} disabled={!!opening||user.tokens<pack.price} style={{width:'100%',padding:'10px',background:user.tokens>=pack.price?`linear-gradient(135deg,${pack.color1},${pack.color2})`:'rgba(255,255,255,0.05)',border:'none',borderRadius:'10px',color:user.tokens>=pack.price?'white':'rgba(255,255,255,0.2)',fontWeight:'700',fontSize:'14px',cursor:user.tokens>=pack.price?'pointer':'not-allowed'}}>
                  {opening===name?'✨ Opening...':`🪙 ${pack.price.toLocaleString()}`}
                </button>
              </div>
            ))}
          </div>
        </>}

        {/* PLAY */}
        {page==='play' && <>
          <h1 style={S.h1}>Play</h1>
          <p style={S.sub}>Multiplayer trivia — compete with friends!</p>

          {/* MENU */}
          {mpMode==='menu' && (
            <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'16px',maxWidth:'600px'}}>
              <div style={{...S.card,textAlign:'center'}}>
                <div style={{fontSize:'48px',marginBottom:'12px'}}>🎮</div>
                <div style={{fontSize:'18px',fontWeight:'800',color:'#e0e7ff',marginBottom:'8px'}}>Host Game</div>
                <div style={{fontSize:'13px',color:'rgba(255,255,255,0.3)',marginBottom:'12px'}}>Create a game and share the code with friends</div>
              <select value={selectedSet?.id||''} onChange={e=>{const s=sets.find(x=>x.id==e.target.value);setSelectedSet(s||null);}} style={{width:'100%',padding:'8px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'8px',color:'white',fontSize:'13px',marginBottom:'12px'}}>
                <option value="">Default questions</option>
                {sets.map(s=><option key={s.id} value={s.id}>{s.title} ({s.question_count}q) — {s.username}</option>)}
              </select>
              <button onClick={hostGame} style={S.btn()}>Host</button>
              </div>
              <div style={{...S.card,textAlign:'center'}}>
                <div style={{fontSize:'48px',marginBottom:'12px'}}>🔑</div>
                <div style={{fontSize:'18px',fontWeight:'800',color:'#e0e7ff',marginBottom:'8px'}}>Join Game</div>
                <div style={{fontSize:'13px',color:'rgba(255,255,255,0.3)',marginBottom:'12px'}}>Enter a code to join a friend's game</div>
                <input value={mpJoinCode} onChange={e=>setMpJoinCode(e.target.value.toUpperCase())} placeholder="Enter code..." maxLength={6} style={{width:'100%',padding:'10px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'8px',color:'white',fontSize:'18px',fontWeight:'700',textAlign:'center',letterSpacing:'4px',marginBottom:'12px',boxSizing:'border-box'}} />
                <button onClick={joinGame} style={S.btn('#22c55e')}>Join</button>
                {mpError && <div style={{color:'#f87171',fontSize:'12px',marginTop:'8px'}}>{mpError}</div>}
              </div>
            </div>
          )}

          {/* LOBBY */}
          {mpMode==='lobby' && (
            <div style={{maxWidth:'500px'}}>
              <div style={{...S.card,textAlign:'center',marginBottom:'16px'}}>
                <div style={{fontSize:'13px',color:'rgba(255,255,255,0.4)',marginBottom:'8px'}}>Game Code</div>
                <div style={{fontSize:'48px',fontWeight:'900',color:'#a5b4fc',letterSpacing:'8px',fontFamily:'monospace'}}>{mpCode}</div>
                <div style={{fontSize:'12px',color:'rgba(255,255,255,0.3)',marginTop:'8px'}}>Share this code with friends!</div>
              </div>
              <div style={{...S.card,marginBottom:'16px'}}>
                <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'12px'}}>Players ({mpPlayers.length})</div>
                {mpPlayers.map((p,i) => (
                  <div key={i} style={{display:'flex',alignItems:'center',gap:'10px',padding:'8px 0',borderBottom:'1px solid rgba(99,102,241,0.08)'}}>
                    <div style={{width:'8px',height:'8px',background:'#22c55e',borderRadius:'50%'}}/>
                    <div style={{fontSize:'14px',fontWeight:'600',color:'#e0e7ff'}}>{p.username}</div>
                    {i===0&&<div style={{fontSize:'11px',color:'#f59e0b',marginLeft:'auto'}}>HOST</div>}
                  </div>
                ))}
              </div>
              <div style={{display:'flex',gap:'10px'}}>
                {mpIsHost && <button onClick={startGame} style={{...S.btn(),flex:1}}>Start Game</button>}
                <button onClick={leaveGame} style={{...S.ghostBtn,flex:mpIsHost?0:1}}>Leave</button>
              </div>
            </div>
          )}

          {/* STARTING */}
          {mpMode==='starting' && (
            <div style={{...S.card,maxWidth:'400px',textAlign:'center',padding:'48px'}}>
              <div style={{fontSize:'48px',marginBottom:'16px'}}>🚀</div>
              <div style={{fontSize:'22px',fontWeight:'800',color:'#e0e7ff'}}>Game Starting!</div>
              <div style={{fontSize:'14px',color:'rgba(255,255,255,0.4)',marginTop:'8px'}}>Get ready...</div>
            </div>
          )}

          {/* PLAYING */}
          {(mpMode==='playing'||mpMode==='answered') && mpQuestion && (
            <div style={{maxWidth:'640px'}}>
              <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'16px'}}>
                <div style={{fontSize:'13px',color:'rgba(255,255,255,0.4)'}}>Question {mpQuestionNum} / {mpTotal}</div>
                <div style={{fontSize:'20px',fontWeight:'800',color:mpTimeLeft<=5?'#ef4444':'#f59e0b'}}>⏱ {mpTimeLeft}s</div>
              </div>
              <div style={{...S.card,marginBottom:'16px',padding:'28px'}}>
                <div style={{fontSize:'20px',fontWeight:'700',color:'#e0e7ff'}}>{mpQuestion.question}</div>
              </div>
              {mpMode==='answered' && mpAnswered && (
                <div style={{...S.card,marginBottom:'16px',textAlign:'center',background:mpAnswered.correct?'rgba(34,197,94,0.1)':'rgba(239,68,68,0.1)',border:`1px solid ${mpAnswered.correct?'rgba(34,197,94,0.3)':'rgba(239,68,68,0.3)'}`}}>
                  <div style={{fontSize:'28px',marginBottom:'4px'}}>{mpAnswered.correct?'✅':'❌'}</div>
                  <div style={{fontSize:'18px',fontWeight:'800',color:mpAnswered.correct?'#22c55e':'#f87171'}}>{mpAnswered.correct?`+${mpAnswered.points} points`:'Wrong!'}</div>
                  <div style={{fontSize:'13px',color:'rgba(255,255,255,0.4)',marginTop:'4px'}}>Waiting for others...</div>
                </div>
              )}
              <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'12px'}}>
                {mpQuestion.answers.map((ans,idx) => {
                  const colors = ['#ef4444','#3b9eff','#22c55e','#f59e0b'];
                  return (
                    <button key={idx} onClick={()=>sendAnswer(idx)} disabled={mpMode==='answered'}
                      style={{background:`${colors[idx]}22`,border:`1px solid ${colors[idx]}55`,borderRadius:'12px',padding:'18px',color:'#e0e7ff',fontWeight:'600',fontSize:'15px',cursor:mpMode==='playing'?'pointer':'default',textAlign:'left',opacity:mpMode==='answered'?0.6:1}}>
                      <span style={{color:colors[idx],marginRight:'8px',fontWeight:'800'}}>{['A','B','C','D'][idx]}.</span>{ans}
                    </button>
                  );
                })}
              </div>
            </div>
          )}

          {/* SCORE SCREEN */}
          {mpMode==='scores' && (
            <div style={{maxWidth:'500px'}}>
              <div style={{...S.card,marginBottom:'16px',textAlign:'center',padding:'20px'}}>
                <div style={{fontSize:'14px',color:'rgba(255,255,255,0.4)',marginBottom:'12px'}}>Scores after question {mpQuestionNum}</div>
                {mpScores.map((p,i) => (
                  <div key={i} style={{display:'flex',justifyContent:'space-between',padding:'8px 12px',background:'rgba(99,102,241,0.08)',borderRadius:'8px',marginBottom:'6px'}}>
                    <div style={{fontWeight:'700',color:'#e0e7ff'}}>{p.username}</div>
                    <div style={{fontWeight:'800',color:'#f59e0b'}}>🪙 {p.score}</div>
                  </div>
                ))}
                <div style={{fontSize:'13px',color:'rgba(255,255,255,0.3)',marginTop:'12px'}}>Next question coming...</div>
              </div>
            </div>
          )}

          {/* GAME OVER */}
          {mpMode==='gameover' && (
            <div style={{maxWidth:'500px'}}>
              <div style={{...S.card,textAlign:'center',marginBottom:'16px'}}>
                <div style={{fontSize:'48px',marginBottom:'12px'}}>🏆</div>
                <div style={{fontSize:'24px',fontWeight:'800',color:'#e0e7ff',marginBottom:'20px'}}>Game Over!</div>
                {mpFinalScores.map((p,i) => (
                  <div key={i} style={{display:'flex',alignItems:'center',gap:'12px',padding:'12px',background:i===0?'rgba(245,158,11,0.1)':'rgba(99,102,241,0.08)',border:`1px solid ${i===0?'rgba(245,158,11,0.3)':'rgba(99,102,241,0.15)'}`,borderRadius:'10px',marginBottom:'8px'}}>
                    <div style={{fontSize:'20px',fontWeight:'900',color:i===0?'#f59e0b':i===1?'#aaa':'#cd7f32',width:'32px'}}>#{i+1}</div>
                    <div style={{flex:1,fontWeight:'700',color:'#e0e7ff'}}>{p.username}</div>
                    <div style={{fontWeight:'800',color:'#f59e0b'}}>🪙 {p.score}</div>
                  </div>
                ))}
                {mpFinalScores[0] && <div style={{fontSize:'13px',color:'rgba(255,255,255,0.3)',marginTop:'12px'}}>Tokens awarded to top 3 players!</div>}
              </div>
              <button onClick={leaveGame} style={{...S.btn(),width:'100%'}}>Back to Menu</button>
            </div>
          )}
        </>}

        {/* SETS */}
        {page==='sets' && <>
          <h1 style={S.h1}>My Sets</h1>
          <p style={S.sub}>Create and manage your question sets</p>
          {!creatingSet && (
            <button onClick={()=>setCreatingSet(true)} style={{...S.btn(),marginBottom:'20px'}}>+ Create Set</button>
          )}
          {creatingSet && (
            <div style={{...S.card,maxWidth:'700px',marginBottom:'20px'}}>
              <div style={{fontSize:'16px',fontWeight:'800',color:'#e0e7ff',marginBottom:'16px'}}>New Set</div>
              <input value={setTitle} onChange={e=>setSetTitle(e.target.value)} placeholder="Set title..." style={{width:'100%',padding:'10px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'8px',color:'white',fontSize:'14px',marginBottom:'10px',boxSizing:'border-box'}} />
              <input value={setDesc} onChange={e=>setSetDesc(e.target.value)} placeholder="Description (optional)..." style={{width:'100%',padding:'10px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'8px',color:'white',fontSize:'14px',marginBottom:'16px',boxSizing:'border-box'}} />
              {setQuestions.map((q,qi) => (
                <div key={qi} style={{background:'rgba(99,102,241,0.06)',border:'1px solid rgba(99,102,241,0.15)',borderRadius:'12px',padding:'16px',marginBottom:'12px'}}>
                  <div style={{fontSize:'13px',fontWeight:'700',color:'rgba(255,255,255,0.4)',marginBottom:'8px'}}>Question {qi+1}</div>
                  <input value={q.question} onChange={e=>{const qs=[...setQuestions];qs[qi]={...qs[qi],question:e.target.value};setSetQuestions(qs);}} placeholder="Question..." style={{width:'100%',padding:'8px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'7px',color:'white',fontSize:'13px',marginBottom:'8px',boxSizing:'border-box'}} />
                  <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'8px',marginBottom:'8px'}}>
                    {q.answers.map((a,ai)=>(
                      <div key={ai} style={{display:'flex',alignItems:'center',gap:'6px'}}>
                        <input type="radio" checked={q.correct===ai} onChange={()=>{const qs=[...setQuestions];qs[qi]={...qs[qi],correct:ai};setSetQuestions(qs);}} />
                        <input value={a} onChange={e=>{const qs=[...setQuestions];const ans=[...qs[qi].answers];ans[ai]=e.target.value;qs[qi]={...qs[qi],answers:ans};setSetQuestions(qs);}} placeholder={`Answer ${ai+1}...`} style={{flex:1,padding:'7px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'7px',color:'white',fontSize:'12px'}} />
                      </div>
                    ))}
                  </div>
                  {setQuestions.length > 1 && <button onClick={()=>setSetQuestions(setQuestions.filter((_,i)=>i!==qi))} style={{fontSize:'12px',color:'#f87171',background:'none',border:'none',cursor:'pointer'}}>Remove</button>}
                </div>
              ))}
              <div style={{display:'flex',gap:'10px',marginTop:'8px'}}>
                <button onClick={()=>setSetQuestions([...setQuestions,{question:'',answers:['','','',''],correct:0}])} style={S.ghostBtn}>+ Add Question</button>
                <button onClick={async()=>{
                  try {
                    const token=localStorage.getItem('token');
                    const res=await axios.post('/api/sets-create',{title:setTitle,description:setDesc,questions:setQuestions},{headers:{authorization:token}});
                    setSets(prev=>[res.data.set,...prev]);
                    setCreatingSet(false);setSetTitle('');setSetDesc('');setSetQuestions([{question:'',answers:['','','',''],correct:0}]);
                  } catch(e){alert(e.response?.data?.error||'Failed');}
                }} style={S.btn()}>Save Set</button>
                <button onClick={()=>setCreatingSet(false)} style={{...S.ghostBtn,color:'#f87171'}}>Cancel</button>
              </div>
            </div>
          )}
          <div style={{display:'flex',flexDirection:'column',gap:'10px',maxWidth:'700px'}}>
            {sets.filter(s=>s.username===user.username).map(s=>(
              <div key={s.id} style={{...S.card,display:'flex',alignItems:'center',gap:'16px'}}>
                <div style={{flex:1}}>
                  <div style={{fontSize:'15px',fontWeight:'700',color:'#e0e7ff'}}>{s.title}</div>
                  <div style={{fontSize:'12px',color:'rgba(255,255,255,0.3)',marginTop:'2px'}}>{s.question_count} questions</div>
                </div>
              </div>
            ))}
            {sets.filter(s=>s.username===user.username).length===0 && !creatingSet && <div style={{color:'rgba(255,255,255,0.2)',fontSize:'13px'}}>No sets yet. Create one above!</div>}
          </div>
        </>}

        {/* DISCOVER */}
        {page==='discover' && <>
          <h1 style={S.h1}>Discover</h1>
          <p style={S.sub}>Browse sets created by the community</p>
          <div style={{display:'flex',flexDirection:'column',gap:'12px',maxWidth:'750px'}}>
            {sets.length===0 && <div style={{color:'rgba(255,255,255,0.2)',fontSize:'13px'}}>No sets yet — be the first to create one!</div>}
            {sets.map(s=>(
              <div key={s.id} style={{...S.card,display:'flex',alignItems:'center',gap:'16px'}}>
                <div style={{flex:1}}>
                  <div style={{fontSize:'15px',fontWeight:'700',color:'#e0e7ff'}}>{s.title}</div>
                  {s.description && <div style={{fontSize:'12px',color:'rgba(255,255,255,0.3)',marginTop:'3px'}}>{s.description}</div>}
                  <div style={{display:'flex',gap:'12px',marginTop:'6px'}}>
                    <span style={{fontSize:'11px',color:'rgba(99,102,241,0.7)'}}>📝 {s.question_count} questions</span>
                    <span style={{fontSize:'11px',color:'rgba(255,255,255,0.3)'}}>by {s.username}</span>
                    <span style={{fontSize:'11px',color:'rgba(255,255,255,0.2)'}}>{new Date(s.created_at).toLocaleDateString()}</span>
                  </div>
                </div>
                <button onClick={()=>{setSelectedSet(s);setPage('play');}} style={{...S.btn(),fontSize:'13px',padding:'9px 18px',whiteSpace:'nowrap'}}>▶ Play</button>
              </div>
            ))}
          </div>
        </>}

        {/* CHAT */}
        {page==='chat' && <ChatPage user={user} />}

        {/* FRIENDS */}
        {page==='friends' && <>
          <h1 style={S.h1}>Friends</h1>
          <p style={S.sub}>Connect with other players</p>
          <div style={{display:'flex',gap:'10px',marginBottom:'24px',maxWidth:'500px'}}>
            <input value={friendInput} onChange={e=>setFriendInput(e.target.value)} onKeyDown={e=>e.key==='Enter'&&sendFriendRequest()} placeholder='Enter username...' style={{flex:1,padding:'10px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'8px',color:'white',fontSize:'14px'}} />
            <button onClick={sendFriendRequest} style={S.btn()}>Add Friend</button>
          </div>
          {friendMsg && <div style={{color:'#22c55e',fontSize:'13px',marginBottom:'12px'}}>{friendMsg}</div>}
          {friendErr && <div style={{color:'#f87171',fontSize:'13px',marginBottom:'12px'}}>{friendErr}</div>}
          
          {/* Pending requests */}
          {friends.filter(f=>f.status==='pending'&&f.requester_id!==user.id).length > 0 && <>
            <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'10px'}}>Pending Requests</div>
            <div style={{display:'flex',flexDirection:'column',gap:'8px',marginBottom:'20px',maxWidth:'500px'}}>
              {friends.filter(f=>f.status==='pending'&&f.requester_id!==user.id).map(f=>(
                <div key={f.id} style={{...S.card,display:'flex',alignItems:'center',gap:'12px',padding:'14px 18px'}}>
                  <img src={'/content/blooks/'+(f.equipped_blook||'Default.png')} style={{width:'36px',height:'36px',borderRadius:'8px'}} />
                  <div style={{flex:1,fontWeight:'700',color:'#e0e7ff'}}>{f.username}</div>
                  <button onClick={()=>friendAction(f.id,'accept')} style={{background:'rgba(34,197,94,0.15)',border:'1px solid rgba(34,197,94,0.3)',borderRadius:'8px',color:'#22c55e',fontSize:'12px',fontWeight:'700',padding:'6px 14px',cursor:'pointer'}}>Accept</button>
                  <button onClick={()=>friendAction(f.id,'decline')} style={{background:'rgba(239,68,68,0.1)',border:'1px solid rgba(239,68,68,0.2)',borderRadius:'8px',color:'#f87171',fontSize:'12px',fontWeight:'700',padding:'6px 14px',cursor:'pointer'}}>Decline</button>
                </div>
              ))}
            </div>
          </>}

          {/* Sent requests */}
          {friends.filter(f=>f.status==='pending'&&f.requester_id===user.id).length > 0 && <>
            <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'10px'}}>Sent Requests</div>
            <div style={{display:'flex',flexDirection:'column',gap:'8px',marginBottom:'20px',maxWidth:'500px'}}>
              {friends.filter(f=>f.status==='pending'&&f.requester_id===user.id).map(f=>(
                <div key={f.id} style={{...S.card,display:'flex',alignItems:'center',gap:'12px',padding:'14px 18px'}}>
                  <img src={'/content/blooks/'+(f.equipped_blook||'Default.png')} style={{width:'36px',height:'36px',borderRadius:'8px'}} />
                  <div style={{flex:1,fontWeight:'700',color:'#e0e7ff'}}>{f.username}</div>
                  <div style={{fontSize:'12px',color:'rgba(255,255,255,0.3)'}}>Pending...</div>
                  <button onClick={()=>friendAction(f.id,'remove')} style={{background:'rgba(239,68,68,0.1)',border:'1px solid rgba(239,68,68,0.2)',borderRadius:'8px',color:'#f87171',fontSize:'12px',fontWeight:'700',padding:'6px 14px',cursor:'pointer'}}>Cancel</button>
                </div>
              ))}
            </div>
          </>}

          {/* Friends */}
          <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'10px'}}>Friends ({friends.filter(f=>f.status==='accepted').length})</div>
          <div style={{display:'flex',flexDirection:'column',gap:'8px',maxWidth:'500px'}}>
            {friends.filter(f=>f.status==='accepted').map(f=>(
              <div key={f.id} style={{...S.card,display:'flex',alignItems:'center',gap:'12px',padding:'14px 18px'}}>
                <img src={'/content/blooks/'+(f.equipped_blook||'Default.png')} style={{width:'40px',height:'40px',borderRadius:'8px'}} />
                <div style={{flex:1}}>
                  <div style={{fontWeight:'700',color:'#e0e7ff'}}>{f.username}</div>
                  <div style={{fontSize:'11px',color:'rgba(255,255,255,0.3)'}}>🪙 {f.tokens?.toLocaleString()}</div>
                </div>
                <button onClick={()=>friendAction(f.id,'remove')} style={{background:'rgba(239,68,68,0.08)',border:'1px solid rgba(239,68,68,0.15)',borderRadius:'8px',color:'#f87171',fontSize:'12px',fontWeight:'600',padding:'6px 14px',cursor:'pointer'}}>Remove</button>
              </div>
            ))}
            {friends.filter(f=>f.status==='accepted').length===0 && <div style={{color:'rgba(255,255,255,0.2)',fontSize:'13px'}}>No friends yet. Add someone above!</div>}
          </div>
        </>}

        {/* TRADE */}
        {page==='trade' && <>
          <h1 style={S.h1}>Trade</h1>
          <p style={S.sub}>Exchange blooks with other players</p>

          {/* Incoming trades */}
          {trades.filter(t=>t.receiver_id===user.id).length > 0 && <>
            <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'10px'}}>Incoming Offers</div>
            <div style={{display:'flex',flexDirection:'column',gap:'10px',marginBottom:'24px',maxWidth:'600px'}}>
              {trades.filter(t=>t.receiver_id===user.id).map(t=>(
                <div key={t.id} style={{...S.card,padding:'16px 20px'}}>
                  <div style={{display:'flex',alignItems:'center',gap:'12px',marginBottom:'12px'}}>
                    <img src={'/content/blooks/'+(t.sender_avatar||'Default.png')} style={{width:'32px',height:'32px',borderRadius:'7px'}} />
                    <div style={{fontWeight:'700',color:'#e0e7ff'}}>{t.sender_username} wants to trade</div>
                  </div>
                  <div style={{display:'flex',alignItems:'center',gap:'16px',marginBottom:'14px'}}>
                    <div style={{textAlign:'center'}}>
                      <img src={'/content/blooks/'+t.sender_blook_name} onError={e=>e.target.src='/content/blooks/Default.png'} style={{width:'56px',height:'56px',borderRadius:'10px',border:'1px solid rgba(99,102,241,0.3)'}} />
                      <div style={{fontSize:'11px',color:'#a5b4fc',marginTop:'4px'}}>{t.sender_blook_name?.replace(/\.(png|gif)/,'')}</div>
                      <div style={{fontSize:'10px',color:'rgba(255,255,255,0.3)'}}>{t.sender_username}'s</div>
                    </div>
                    <div style={{fontSize:'24px',color:'rgba(255,255,255,0.3)'}}>⇄</div>
                    <div style={{textAlign:'center'}}>
                      {t.receiver_blook_name ? <>
                        <img src={'/content/blooks/'+t.receiver_blook_name} onError={e=>e.target.src='/content/blooks/Default.png'} style={{width:'56px',height:'56px',borderRadius:'10px',border:'1px solid rgba(99,102,241,0.3)'}} />
                        <div style={{fontSize:'11px',color:'#a5b4fc',marginTop:'4px'}}>{t.receiver_blook_name?.replace(/\.(png|gif)/,'')}</div>
                        <div style={{fontSize:'10px',color:'rgba(255,255,255,0.3)'}}>Your blook</div>
                      </> : <div style={{fontSize:'13px',color:'rgba(255,255,255,0.3)',width:'56px'}}>Nothing in return</div>}
                    </div>
                  </div>
                  <div style={{display:'flex',gap:'8px'}}>
                    <button onClick={async()=>{await axios.post('/api/trades-action',{tradeId:t.id,action:'accept'},{headers:{authorization:localStorage.getItem('token')}});axios.get('/api/trades',{headers:{authorization:localStorage.getItem('token')}}).then(r=>setTrades(r.data));axios.get('/api/users/me',{headers:{authorization:localStorage.getItem('token')}}).then(r=>setUser(prev=>({...r.data.user,blooks:prev.blooks})));}} style={{background:'rgba(34,197,94,0.15)',border:'1px solid rgba(34,197,94,0.3)',borderRadius:'8px',color:'#22c55e',fontSize:'13px',fontWeight:'700',padding:'8px 20px',cursor:'pointer'}}>Accept</button>
                    <button onClick={async()=>{await axios.post('/api/trades-action',{tradeId:t.id,action:'decline'},{headers:{authorization:localStorage.getItem('token')}});axios.get('/api/trades',{headers:{authorization:localStorage.getItem('token')}}).then(r=>setTrades(r.data));}} style={{background:'rgba(239,68,68,0.1)',border:'1px solid rgba(239,68,68,0.2)',borderRadius:'8px',color:'#f87171',fontSize:'13px',fontWeight:'700',padding:'8px 20px',cursor:'pointer'}}>Decline</button>
                  </div>
                </div>
              ))}
            </div>
          </>}

          {/* Sent trades */}
          {trades.filter(t=>t.sender_id===user.id).length > 0 && <>
            <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'10px'}}>Sent Offers</div>
            <div style={{display:'flex',flexDirection:'column',gap:'10px',marginBottom:'24px',maxWidth:'600px'}}>
              {trades.filter(t=>t.sender_id===user.id).map(t=>(
                <div key={t.id} style={{...S.card,display:'flex',alignItems:'center',gap:'12px',padding:'14px 18px'}}>
                  <div style={{flex:1,fontSize:'14px',color:'#e0e7ff'}}>
                    Offer to <span style={{fontWeight:'700'}}>{t.receiver_username}</span>: {t.sender_blook_name?.replace(/\.(png|gif)/,'')} {t.receiver_blook_name ? `↔ ${t.receiver_blook_name.replace(/\.(png|gif)/,'')}` : '(gift)'}
                  </div>
                  <button onClick={async()=>{await axios.post('/api/trades-action',{tradeId:t.id,action:'cancel'},{headers:{authorization:localStorage.getItem('token')}});axios.get('/api/trades',{headers:{authorization:localStorage.getItem('token')}}).then(r=>setTrades(r.data));}} style={{background:'rgba(239,68,68,0.08)',border:'1px solid rgba(239,68,68,0.15)',borderRadius:'8px',color:'#f87171',fontSize:'12px',padding:'6px 14px',cursor:'pointer'}}>Cancel</button>
                </div>
              ))}
            </div>
          </>}

          {/* New trade */}
          <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(255,255,255,0.3)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'12px'}}>New Trade Offer</div>
          <div style={{...S.card,maxWidth:'600px'}}>
            <div style={{marginBottom:'14px'}}>
              <label style={{fontSize:'13px',color:'rgba(255,255,255,0.4)',marginBottom:'6px',display:'block'}}>Send to (username)</label>
              <div style={{display:'flex',gap:'8px'}}>
                <input value={tradeTarget} onChange={e=>setTradeTarget(e.target.value)} placeholder='Username...' style={{flex:1,padding:'9px',background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'8px',color:'white',fontSize:'13px'}} />
                <button onClick={async()=>{
                  setTradeErr('');
                  try {
                    const token = localStorage.getItem('token');
                    const [theirRes, myRes] = await Promise.all([
                      axios.get('/api/users/blooks-by?username='+tradeTarget, {headers:{authorization:token}}),
                      axios.get('/api/users/blooks-by?username='+user.username, {headers:{authorization:token}})
                    ]);
                    setTradeTargetBlooks(theirRes.data);
                    setTradeMyBlooks(myRes.data);
                    setTradeStep('selectMyBlook');
                    setTradeMsg('');
                  } catch(e) { setTradeErr(e.response?.data?.error||'User not found'); }
                }} style={S.btn()}>Next</button>
              </div>
            </div>

            {tradeStep !== 'main' && <>
              <div style={{marginBottom:'14px'}}>
                <label style={{fontSize:'13px',color:'rgba(255,255,255,0.4)',marginBottom:'8px',display:'block'}}>Your blook to offer {tradeMyBlook && <span style={{color:'#a5b4fc'}}>✓ {tradeMyBlook.blook_name?.replace(/\.(png|gif)/,'')}</span>}</label>
                <div style={{display:'flex',flexWrap:'wrap',gap:'8px',maxHeight:'160px',overflowY:'auto'}}>
                  {tradeMyBlooks.map((b,i)=>(
                    <div key={i} onClick={()=>setTradeMyBlook(b)} style={{background:tradeMyBlook?.id===b.id?'rgba(99,102,241,0.3)':'rgba(99,102,241,0.08)',border:`1px solid ${tradeMyBlook?.id===b.id?'rgba(99,102,241,0.6)':'rgba(99,102,241,0.2)'}`,borderRadius:'10px',padding:'8px',textAlign:'center',cursor:'pointer',width:'72px'}}>
                      <img src={'/content/blooks/'+b.blook_name} onError={e=>e.target.src='/content/blooks/Default.png'} style={{width:'40px',height:'40px',objectFit:'contain'}} />
                      <div style={{fontSize:'10px',color:'#a5b4fc',marginTop:'3px'}}>{b.blook_name?.replace(/\.(png|gif)/,'')}</div>
                    </div>
                  ))}
                </div>
              </div>

              <div style={{marginBottom:'14px'}}>
                <label style={{fontSize:'13px',color:'rgba(255,255,255,0.4)',marginBottom:'8px',display:'block'}}>Their blook to request (optional) {tradeTheirBlook && <span style={{color:'#a5b4fc'}}>✓ {tradeTheirBlook.blook_name?.replace(/\.(png|gif)/,'')}</span>}</label>
                <div style={{display:'flex',flexWrap:'wrap',gap:'8px',maxHeight:'160px',overflowY:'auto'}}>
                  {tradeTargetBlooks.map((b,i)=>(
                    <div key={i} onClick={()=>setTradeTheirBlook(tradeTheirBlook?.id===b.id?null:b)} style={{background:tradeTheirBlook?.id===b.id?'rgba(99,102,241,0.3)':'rgba(99,102,241,0.08)',border:`1px solid ${tradeTheirBlook?.id===b.id?'rgba(99,102,241,0.6)':'rgba(99,102,241,0.2)'}`,borderRadius:'10px',padding:'8px',textAlign:'center',cursor:'pointer',width:'72px'}}>
                      <img src={'/content/blooks/'+b.blook_name} onError={e=>e.target.src='/content/blooks/Default.png'} style={{width:'40px',height:'40px',objectFit:'contain'}} />
                      <div style={{fontSize:'10px',color:'#a5b4fc',marginTop:'3px'}}>{b.blook_name?.replace(/\.(png|gif)/,'')}</div>
                    </div>
                  ))}
                  {tradeTargetBlooks.length===0 && <div style={{fontSize:'13px',color:'rgba(255,255,255,0.2)'}}>This user has no blooks</div>}
                </div>
              </div>

              {tradeMsg && <div style={{color:'#22c55e',fontSize:'13px',marginBottom:'10px'}}>{tradeMsg}</div>}
              {tradeErr && <div style={{color:'#f87171',fontSize:'13px',marginBottom:'10px'}}>{tradeErr}</div>}
              <div style={{display:'flex',gap:'8px'}}>
                <button onClick={async()=>{
                  if (!tradeMyBlook) return setTradeErr('Select a blook to offer.');
                  setTradeErr('');
                  try {
                    await axios.post('/api/trades-send',{receiverUsername:tradeTarget,senderBlookId:tradeMyBlook.id,receiverBlookId:tradeTheirBlook?.id||null},{headers:{authorization:localStorage.getItem('token')}});
                    setTradeMsg('Trade offer sent!');
                    setTradeMyBlook(null);setTradeTheirBlook(null);setTradeStep('main');setTradeTarget('');
                    axios.get('/api/trades',{headers:{authorization:localStorage.getItem('token')}}).then(r=>setTrades(r.data));
                  } catch(e){setTradeErr(e.response?.data?.error||'Failed');}
                }} style={S.btn()}>Send Offer</button>
                <button onClick={()=>{setTradeStep('main');setTradeMyBlook(null);setTradeTheirBlook(null);setTradeErr('');}} style={S.ghostBtn}>Cancel</button>
              </div>
            </>}
          </div>
        </>}

        {/* LEADERBOARD */}
        {page==='leaderboard' && <>
          <h1 style={S.h1}>Leaderboard</h1>
          <p style={S.sub}>Top players</p>
          <div style={{display:'flex',flexDirection:'column',gap:'10px',maxWidth:'700px'}}>
            {leaderboard.map((u,i) => (
              <div key={u.id} style={{display:'flex',alignItems:'center',gap:'16px',background:i===0?'rgba(245,158,11,0.08)':'linear-gradient(135deg,#0d1240,#0a0f2e)',border:`1px solid ${i===0?'rgba(245,158,11,0.3)':i===1?'rgba(160,160,160,0.2)':i===2?'rgba(180,100,30,0.2)':'rgba(99,102,241,0.15)'}`,borderRadius:'12px',padding:'16px 20px'}}>
                <div style={{fontFamily:'Titan One,sans-serif',fontSize:'24px',width:'40px',textAlign:'center',color:i===0?'#f59e0b':i===1?'#aaa':i===2?'#cd7f32':'rgba(255,255,255,0.2)'}}>#{i+1}</div>
                <img src={`/content/blooks/${u.equipped_blook||'Default.png'}`} style={{width:'40px',height:'40px',borderRadius:'8px'}} />
                <div style={{flex:1,fontSize:'16px',fontWeight:'700',color:'#e0e7ff'}}>{u.username}</div>
                <div style={{fontSize:'16px',fontWeight:'800',color:'#f59e0b'}}>🪙 {u.tokens?.toLocaleString()}</div>
              </div>
            ))}
          </div>
        </>}

        {/* SETTINGS */}
        {page==='dev' && user?.role==='Dev' && <DevPanel user={user} />}
        {page==='settings' && <>
          <h1 style={S.h1}>Settings</h1>
          <p style={S.sub}>Manage your account</p>
          <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'16px',maxWidth:'820px'}}>
            <div style={S.card}>
              <div style={{display:'flex',alignItems:'center',gap:'10px',marginBottom:'16px'}}>
                <span style={{fontSize:'18px'}}>👤</span>
                <span style={{fontSize:'16px',fontWeight:'800',color:'#e0e7ff'}}>Profile</span>
              </div>
              {[['Username',user.username],['Role','Common'],['Joined',new Date(user.created_at).toLocaleDateString()]].map(([k,v])=>(
                <div key={k} style={{display:'flex',gap:'6px',marginBottom:'6px',fontSize:'14px'}}>
                  <span style={{color:'rgba(255,255,255,0.4)',fontWeight:'600'}}>{k}:</span>
                  <span style={{color:'#e0e7ff'}}>{v}</span>
                </div>
              ))}
            </div>
            <div style={S.card}>
              <div style={{display:'flex',alignItems:'center',gap:'10px',marginBottom:'16px'}}>
                <span style={{fontSize:'18px'}}>⭐</span>
                <span style={{fontSize:'16px',fontWeight:'800',color:'#e0e7ff'}}>Plan</span>
              </div>
              <div style={{fontSize:'20px',fontWeight:'800',background:'linear-gradient(135deg,#818cf8,#c7d2fe)',WebkitBackgroundClip:'text',WebkitTextFillColor:'transparent',marginBottom:'12px'}}>Lacket Basic</div>
              <div style={{fontSize:'13px',color:'rgba(255,255,255,0.3)',marginBottom:'14px'}}>You are on the free plan.</div>
              <div style={{background:'linear-gradient(135deg,#6366f1,#3b9eff)',borderRadius:'10px',padding:'10px 18px',display:'inline-block',fontSize:'13px',fontWeight:'700',color:'white',cursor:'default'}}>Current Plan</div>
            </div>
            <div style={S.card}>
              <div style={{display:'flex',alignItems:'center',gap:'10px',marginBottom:'16px'}}>
                <span style={{fontSize:'18px'}}>✏️</span>
                <span style={{fontSize:'16px',fontWeight:'800',color:'#e0e7ff'}}>Edit Info</span>
              </div>
              <ChangePasswordForm user={user} />
            </div>
            <div style={S.card}>
              <div style={{display:'flex',alignItems:'center',gap:'10px',marginBottom:'16px'}}>
                <span style={{fontSize:'18px'}}>⚙️</span>
                <span style={{fontSize:'16px',fontWeight:'800',color:'#e0e7ff'}}>General</span>
              </div>
              <div style={{fontSize:'14px',color:'rgba(255,255,255,0.4)',marginBottom:'16px'}}>🪙 Tokens: <span style={{color:'#f59e0b',fontWeight:'700'}}>{user.tokens?.toLocaleString()}</span></div>
              <div style={{borderTop:'1px solid rgba(99,102,241,0.1)',paddingTop:'16px'}}>
                <div style={{fontSize:'12px',fontWeight:'700',color:'rgba(239,68,68,0.6)',textTransform:'uppercase',letterSpacing:'0.8px',marginBottom:'10px'}}>Danger Zone</div>
                <button onClick={logout} style={{background:'rgba(239,68,68,0.15)',border:'1px solid rgba(239,68,68,0.3)',borderRadius:'9px',color:'#f87171',fontSize:'13px',fontWeight:'600',padding:'9px 20px',cursor:'pointer'}}>Logout</button>
              </div>
            </div>
          </div>
        </>}

      </div>
    </div>
  );
}
